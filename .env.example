# MongoDB Atlas Connection String
# For Vercel deployment, use a MongoDB Atlas SRV connection string (not private IP)
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hris?retryWrites=true&w=majority"

# NextAuth.js Configuration
# Generate a secret with: openssl rand -base64 32
# For Vercel, NEXTAUTH_URL is auto-detected — omit it or set to your production URL
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Redis (Optional — for caching, not required)
REDIS_URL="redis://localhost:6379"