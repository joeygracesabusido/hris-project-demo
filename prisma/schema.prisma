// Prisma Schema for HRIS Philippines - MongoDB
// This schema defines the database models for a Human Resource Information System
// compliant with Philippine labor laws and payroll calculations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MODELS
// ============================================================================

/// User role enum
enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

/// Employee status enum for Philippine labor law compliance
enum EmployeeStatus {
  PROBATIONARY   // 6 months trial period
  REGULAR        // Permanently employed
}

/// User model for authentication
/// Links to Employee record for role-based access
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  username      String    @unique
  email         String    @unique
  name          String?
  password      String?
  role          Role      @default(EMPLOYEE)
  status        String    @default("FOR_APPROVAL")
  image         String?
  emailVerified DateTime?

  failedAttempts Int      @default(0)
  lockUntil      DateTime?

  employees      Employee[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

/// Employee model containing HR-related information
model Employee {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  userId        String?   @db.ObjectId
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  employeeNumber Int?     @unique
  fullName      String
  email         String    @unique

  employeeId    String    @unique
  position      String

  subDepartmentId    String?   @db.ObjectId
  subDepartment      SubDepartment? @relation(fields: [subDepartmentId], references: [id])

  projectId          String?   @db.ObjectId
  project            Project? @relation(fields: [projectId], references: [id])

  basicSalary   Float
  dailyRate     Float     @default(0)
  payrollDivisor Int       @default(26)
  payType       String    @default("MONTHLY") // MONTHLY or DAILY
  payrollFrequency String @default("MONTHLY")

  hireDate      DateTime
  endDate       DateTime?
  isActive      Boolean   @default(true)
  faceDescriptor Float[]   // Biometric face descriptor for recognition
  employeeStatus    EmployeeStatus @default(PROBATIONARY)
  regularizationDate DateTime?     // Date when probationary became regular

  tin           String
  sssNo         String
  philhealthNo  String
  pagibigNo     String

  bankName      String?
  bankAccountNo String?

  managerId     String?   @db.ObjectId
  manager       Employee? @relation("ReportingLine", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates  Employee[] @relation("ReportingLine")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  timeLogs      TimeLog[]
  payrolls      Payroll[]
  leaveRequests LeaveRequest[] @relation("EmployeeLeaves")
  approvedLeaves LeaveRequest[] @relation("ApproverLeaves")
  overtimeRequests OvertimeRequest[] @relation("EmployeeOvertime")
  approvedOvertime OvertimeRequest[] @relation("ApproverOvertime")
  advances      Advance[]
  leaveCredits    LeaveCredit[]
  shiftSchedules ShiftSchedule[]

  @@index([subDepartmentId])
  @@index([projectId])
  @@index([isActive])
  @@index([userId])
  @@map("employees")
  }

  /// Shift model for defining working hours
  model Shift {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    name        String   @unique // e.g., AM_0800_1700, NIGHT_SHIFT
    startTime   String   // e.g., "08:00"
    endTime     String   // e.g., "17:00"
    color       String?  // hex or tailwind class
    isOff       Boolean  @default(false)
    gracePeriodMinutes Int @default(0) // Grace period before counting as late (DOLE compliant)
    
    schedules   ShiftSchedule[]
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@map("shifts")
  }

  /// ShiftSchedule model for assigning shifts to employees on specific dates
  model ShiftSchedule {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    employeeId  String   @db.ObjectId
    employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
    
    shiftId     String   @db.ObjectId
    shift       Shift    @relation(fields: [shiftId], references: [id])
    
    date        DateTime
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@unique([employeeId, date])
    @@map("shiftschedules")
  }

  /// Advance model for employee loans (Cash Advance, SSS, Pag-IBIG)
  model Advance {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  employeeId       String           @db.ObjectId
  employee         Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type             String           // CASH_ADVANCE, SSS_LOAN, PAGIBIG_LOAN
  totalAmount      Float
  remainingBalance Float
  deductionAmount  Float            // Amount to deduct per payroll

  status           String           @default("ACTIVE") // ACTIVE, FULLY_PAID
  date             DateTime?        @default(now())
  reference        String?

  payments         AdvancePayment[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([employeeId, status])
  @@map("advances")
  }

  /// AdvancePayment model for tracking deductions
  model AdvancePayment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  advanceId   String   @db.ObjectId
  advance     Advance  @relation(fields: [advanceId], references: [id], onDelete: Cascade)

  payrollId   String?  @db.ObjectId
  payroll     Payroll? @relation(fields: [payrollId], references: [id])

  amount      Float
  balanceAfter Float
  paymentDate DateTime @default(now())

  notes       String?

  @@index([advanceId])
  @@index([payrollId])
  @@index([paymentDate])
  @@map("advancepayments")
  }

  /// LeaveRequest status enum
enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Overtime status enum
enum OtStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Leave credit ledger types
enum LeaveCreditType {
  MONTHLY_ACCRUAL    // Monthly accrual
  ADJUSTMENT         // Manual adjustment by HR
  USED               // Deducted when leave approved
  CARRY_FORWARD      // Year-end carry over
  EXPIRED            // Unused credits that expired
}

/// LeaveRequest model for filing and approving leaves
model LeaveRequest {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId

  employeeId   String      @db.ObjectId
  employee     Employee    @relation("EmployeeLeaves", fields: [employeeId], references: [id], onDelete: Cascade)
  
  approverId   String?     @db.ObjectId
  approver     Employee?   @relation("ApproverLeaves", fields: [approverId], references: [id])
  
  leaveType    String      // e.g., VACATION, SICK, EMERGENCY, MATERNITY, PATERNITY
  startDate    DateTime
  endDate      DateTime
  daysCount    Float
  reason       String
  status       LeaveStatus @default(PENDING)
  
  adminNotes   String?     // Notes from the approver
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([employeeId, status])
  @@index([startDate, endDate])
  @@map("leaverequests")
}

/// OvertimeRequest model for filing and approving overtime
model OvertimeRequest {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId

  employeeId   String      @db.ObjectId
  employee     Employee    @relation("EmployeeOvertime", fields: [employeeId], references: [id], onDelete: Cascade)
  
  approverId   String?     @db.ObjectId
  approver     Employee?   @relation("ApproverOvertime", fields: [approverId], references: [id])
  
  date         DateTime
  hours        Float
  reason       String
  status       OtStatus    @default(PENDING)
  
  adminNotes   String?     // Notes from the approver
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([employeeId, status])
  @@index([date])
  @@map("overtimerequests")
}

/// LeaveCredit model for tracking employee leave balances
model LeaveCredit {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  
  employeeId      String   @db.ObjectId
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  leaveType       String   @default("VACATION") // VACATION, SICK
  totalDays       Float    @default(0)         // Total accrued days
  usedDays        Float    @default(0)         // Days already used
  availableDays   Float    @default(0)         // Available for use
  year            Int      // For yearly tracking
  
  transactions    LeaveCreditTransaction[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([employeeId, leaveType, year])
  @@index([employeeId])
  @@map("leavecredits")
}

/// LeaveCreditTransaction model for audit trail
model LeaveCreditTransaction {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  
  leaveCreditId   String          @db.ObjectId
  leaveCredit     LeaveCredit     @relation(fields: [leaveCreditId], references: [id], onDelete: Cascade)
  
  type            LeaveCreditType
  days            Float           // Positive for credit, negative for debit
  balanceBefore   Float
  balanceAfter    Float
  
  description     String          // e.g., "Monthly accrual for January 2026"
  referenceId     String?         // LeaveRequest ID if type is USED
  
  createdAt       DateTime        @default(now())
  
  @@index([leaveCreditId])
  @@map("leavecredittransactions")
}

/// HolidayType enum for Philippine labor law compliance
enum HolidayType {
  REGULAR          // 200% pay if work, 100% if no work
  SPECIAL          // 150% pay if work, 100% if no work
  SPECIAL_NON_WORK // Normal pay if work, no pay if no work
}

/// OfficeLocation model for GPS geofencing
model OfficeLocation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  latitude    Float
  longitude   Float
  radius      Int      @default(5) // in meters
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("officelocations")
}

/// Holiday model for managing company holidays
model Holiday {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  date      DateTime    @db.Date
  year      Int
  type      HolidayType
  branchId  String?     @db.ObjectId
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([date, branchId])
  @@index([year])
  @@index([branchId])
  @@map("holidays")
}

model Department {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  code        String    @unique
  description String?
  isActive    Boolean   @default(true)

  subDepartments SubDepartment[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("departments")
}

model SubDepartment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String    @unique
  description String?
  isActive    Boolean   @default(true)

  departmentId String   @db.ObjectId
  department   Department @relation(fields: [departmentId], references: [id])

  projects     Project[]
  employees    Employee[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("subdepartments")
}

model Project {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String    @unique
  description String?
  isActive    Boolean   @default(true)

  subDepartmentId String @db.ObjectId
  subDepartment   SubDepartment @relation(fields: [subDepartmentId], references: [id])

  employees   Employee[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("projects")
}

/// TimeLog model for daily attendance tracking
model TimeLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId

  employeeId  String    @db.ObjectId
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date        DateTime
  clockIn     DateTime?
  clockOut    DateTime?

  workHours   Float     @default(0)
  otHours     Float     @default(0)
  otStatus    OtStatus  @default(PENDING)
  lateMinutes Float     @default(0)
  undertimeMinutes Float @default(0)

  clockInLatitude   Float?
  clockInLongitude  Float?
  clockOutLatitude  Float?
  clockOutLongitude Float?

  notes       String?

  isEdited    Boolean   @default(false)
  editedBy    String?
  editReason  String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([employeeId, date])
  @@map("timelogs")
}

/// Payroll model for monthly payroll records
model Payroll {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId

  employeeId  String    @db.ObjectId
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month       Int
  year        Int
  periodStart DateTime
  periodEnd   DateTime

  basicSalary     Float     @default(0)
  dailyRate      Float     @default(0)
  workDays       Float     @default(0)
  daysWorked     Float     @default(0)

  otHours         Float     @default(0)
  otPay           Float     @default(0)
  holidayPay      Float     @default(0)

  grossPay        Float     @default(0)

  sssEmployee     Float     @default(0)
  sssEmployer     Float     @default(0)
  philhealthEmployee Float  @default(0)
  philhealthEmployer Float  @default(0)
  pagibigEmployee Float     @default(0)
  pagibigEmployer Float     @default(0)

  withholdingTax Float     @default(0)

  lateMinutes       Float    @default(0)
  undertimeMinutes  Float    @default(0)
  lateDeduction     Float    @default(0)
  undertimeDeduction Float   @default(0)

  otherDeductions Float    @default(0)

  adjustmentAdd      Float    @default(0)
  adjustmentDeduct   Float    @default(0)
  adjustmentReason   String?

  totalDeductions Float    @default(0)
  netPay          Float    @default(0)

  status          String    @default("DRAFT")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  processedAt     DateTime?
  approvedBy      String?
  approvedAt      DateTime?

  advancePayments AdvancePayment[]

  @@unique([employeeId, periodStart, periodEnd])
  @@index([employeeId, month, year])
  @@map("payrolls")
}
